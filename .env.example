ANTHROPIC_API_KEY=sk-ant-...

# GitHub auth: GitHub App only.
GITHUB_APP_ID=123456
# GITHUB_APP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# Or point to a runtime-mounted PEM file instead of using the inline key:
# GITHUB_APP_PRIVATE_KEY_PATH=/data/secrets/github-app-private-key.pem
# Optional. If omitted, the app installation is resolved from owner/repo.
# GITHUB_APP_INSTALLATION_ID=987654

# Optional. Set in production (Fly.io) to start a Cloudflare Tunnel sidecar.
# See docs/deploy-fly.md for details.
# CLOUDFLARE_TUNNEL_TOKEN=eyJh...

# Optional. Comma-separated source IP CIDRs allowed by the MCP gateway.
# Defaults to Claude Managed Agents outbound IPs from Anthropic's IP docs.
# MCP_GATEWAY_ALLOWED_CLIENT_CIDRS=160.79.104.0/21

# --- Local development MCP tunnel (ngrok + mcp-gateway + mcp-proxy) ---
# See docs/DEVELOPMENT.md for setup details.
#
# When ENABLE_DEV_TUNNEL=true, `bun run start` will:
#   1. spawn the Python `mcp-proxy` CLI (`pip install mcp-proxy` required),
#   2. start the mcp-gateway in-process,
#   3. open an ngrok tunnel against the gateway, and
#   4. upsert `mcp_servers` rows so Managed Agents can reach the tunnel URL.
# Production (Fly.io with Cloudflare Tunnel) should leave this unset.
# ENABLE_DEV_TUNNEL=true

# ngrok authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
# Required when ENABLE_DEV_TUNNEL=true.
# NGROK_AUTHTOKEN=2x...

# Bearer token used by Managed Agents to call the local MCP gateway. Required
# when ENABLE_DEV_TUNNEL=true. Keep this stable across restarts; rotating it
# leaves dangling MCP credentials in the Anthropic Vault.
# MCP_GATEWAY_TOKEN=replace-with-uuidgen

# Optional. Comma-separated subset of named servers from mcp-proxy.json to
# expose through the tunnel. Defaults to all entries in mcp-proxy.json.
# DEV_TUNNEL_TARGET_SERVERS=figma

# Optional. Strip NODE_EXTRA_CA_CERTS from the env propagated to mcp-proxy
# and its npx children. Set to true when an interactive-shell helper
# (e.g. socket-firewall) points NODE_EXTRA_CA_CERTS at a temp CA file that
# the subprocess cannot use; without dropping it, npx fails with
# UNABLE_TO_GET_ISSUER_CERT_LOCALLY when fetching from the npm registry.
# See docs/DEVELOPMENT.md.
# DEV_TUNNEL_DROP_NODE_EXTRA_CA_CERTS=true

# --- GitHub Issue auto-trigger (polling) ---
# The set of polled repositories is managed at runtime via the WebUI
# (`/repositories` page → "Add polled repository" form). The poller is always
# started; an empty list simply means each cycle is a no-op.

# Polling interval in seconds (default: 60).
# GITHUB_TRIGGER_POLL_INTERVAL_SECONDS=60

# GitHub username (no `@`) that triggers a run when an issue comment
# starts with `@<bot> run` (default: bot).
# GITHUB_BOT_MENTION=bot

# Issue label whose addition triggers a run (default: agent-run).
# GITHUB_TRIGGER_LABEL=agent-run
